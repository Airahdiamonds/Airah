# Backend. Copy to .env.development / .env.production and fill in.

# Server
PORT=4001
FRONTEND_URL=http://localhost:3006

# Postgres (used by drizzle.config.js + db.js)
DATABASE_URL=postgres://postgres:password@localhost:5433/airnah
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=airnah

# Upstash Redis (sessions)
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-me

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=http://localhost:4001/api/auth/google/callback

# Email (nodemailer)
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Ngrok (development only)
NGROK_AUTHTOKEN=
