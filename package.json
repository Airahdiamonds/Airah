{
  "name": "diamond",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@reduxjs/toolkit": "^2.3.0",
    "aos": "^2.3.4",
    "axios": "^1.7.7",
    "framer-motion": "^12.4.1",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.3.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.26.2",
    "react-slick": "^0.30.3",
    "react-toastify": "^10.0.6",
    "redux-persist": "^6.0.0",
    "slick-carousel": "^1.8.1",
    "swiper": "^12.1.4",
    "uuid": "^14.0.0"
  },
  "scripts": {
    "start": "vite",
    "start:dev": "vite --mode development",
    "start:prod": "vite build --mode production",
    "build": "vite build",
    "preview": "vite preview",
    "dev": "concurrently \"npm run start:dev\" \"npm run server\" \"npm run db\"",
    "server": "cd backend && npm run start:dev",
    "db": "cd backend && npm run db:studio:dev",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "happy-dom": "^20.10.4",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    }
  }
}
